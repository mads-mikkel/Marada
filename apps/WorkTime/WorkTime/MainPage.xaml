<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkTime.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="25"
                             Padding="30,0"
                             VerticalOptions="Center">

            <Button x:Name="InBtn"
                    Text="Ind"
                    SemanticProperties.Hint="Stempel ind"
                    Clicked="InClicked"
                    HorizontalOptions="Center"
                    BackgroundColor="Green"
                    TextColor="WhiteSmoke"
                    WidthRequest="200"
                    HeightRequest="50"
                    FontSize="25"/>

            <Button x:Name="OutBtn"
                    Text="Ud"
                    SemanticProperties.Hint="Stempel ud"
                    Clicked="OutBtn_Clicked"
                    HorizontalOptions="Center"
                    BackgroundColor="Red"
                    TextColor="WhiteSmoke"
                    WidthRequest="200"
                    HeightRequest="50"
                    FontSize="25" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
